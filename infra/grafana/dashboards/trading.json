{
  "annotations": {"list": []},
  "description": "Forex Bot — Live trading metrics (engines, signals, fills). Owner: Hestia.",
  "editable": true,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "sum(live_engine_healthy)", "refId": "A"}
      ],
      "title": "Healthy live engines",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area"},
      "targets": [
        {"expr": "sum(daily_pnl_usd)", "refId": "A"}
      ],
      "title": "Total P&L today",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "sum(rate(signals_generated_total[1m]))", "refId": "A"}
      ],
      "title": "Signals/sec (1m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.9},
              {"color": "green", "value": 0.98}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "sum(rate(orders_filled_total[15m])) / clamp_min(sum(rate(orders_submitted_total[15m])), 0.0001)",
          "refId": "A"
        }
      ],
      "title": "Fill rate (15m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line"}, "unit": "currencyUSD"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 10,
      "targets": [
        {"expr": "sum by (user_id) (daily_pnl_usd)", "legendFormat": "user {{user_id}}", "refId": "A"}
      ],
      "title": "Daily P&L by user",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 11,
      "targets": [
        {"expr": "sum by (strategy_code) (rate(signals_generated_total[5m]))", "legendFormat": "{{strategy_code}}", "refId": "A"}
      ],
      "title": "Signals/min by strategy",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line"}, "unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 12,
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(mt5_order_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(mt5_order_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(mt5_order_latency_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "title": "MT5 order latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "bars"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 13,
      "targets": [
        {"expr": "sum by (reason) (increase(kill_switch_triggered_total[1d]))", "legendFormat": "{{reason}}", "refId": "A"}
      ],
      "title": "Kill switch triggers (24h)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "id": 14,
      "options": {"showHeader": true},
      "targets": [
        {
          "expr": "live_engine_healthy",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Live engines table",
      "type": "table"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["forex-bot", "trading"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "name": "DS_PROM",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "title": "Forex Bot — Trading",
  "uid": "forex-bot-trading",
  "version": 1
}
