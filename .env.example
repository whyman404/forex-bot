# ============================================================================
# .env.example — Forex Bot Platform
# ============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
#
# Secrets marked PLACEHOLDER will be auto-generated by `./scripts/dev.sh`
# on first run if left unchanged.
#
# Each variable is annotated with where it belongs:
#   # DEV     — set in this file for local docker-compose
#   # RAILWAY — set in Railway dashboard (backend/engine/worker shared vars)
#   # VERCEL  — set in Vercel dashboard (frontend only)
#   # ALL     — set in all three
#
# Full mapping table: docs/deployment/env-variables.md
# ============================================================================

# ---------------------------------------------------------------------------
# Environment selection
# ---------------------------------------------------------------------------
APP_ENV=development                  # DEV=development | RAILWAY=production
NODE_ENV=development                 # DEV=development | VERCEL=production (auto)
IMAGE_TAG=local                      # DEV — Railway/Vercel manage their own
LOG_LEVEL=INFO                       # ALL

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=forexbot               # DEV — RAILWAY plugin sets PGUSER automatically
POSTGRES_PASSWORD=forexbot           # DEV — RAILWAY plugin sets PGPASSWORD automatically
POSTGRES_DB=forexbot                 # DEV — RAILWAY plugin sets PGDATABASE automatically
POSTGRES_HOST=postgres               # DEV
POSTGRES_PORT=5432                   # DEV

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis                     # DEV — RAILWAY: use REDIS_URL only
REDIS_PORT=6379                      # DEV — RAILWAY: use REDIS_URL only

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://forexbot:forexbot@postgres:5432/forexbot  # ALL — RAILWAY uses Postgres/Neon URL; ensure asyncpg dialect
REDIS_URL=redis://redis:6379/0       # ALL — RAILWAY uses Redis/Upstash URL (Upstash: rediss://)
BACKEND_HOST=0.0.0.0                 # DEV
BACKEND_PORT=8000                    # DEV — RAILWAY injects $PORT at runtime

# Secrets — leave as PLACEHOLDER and dev.sh will rotate them in.
# NOTE: variable names must match app/core/config.py (Settings model).
JWT_SECRET_KEY=PLACEHOLDER_JWT_SECRET_REPLACE_ME              # RAILWAY — openssl rand -base64 32
JWT_ALGORITHM=HS256                                           # ALL
JWT_ACCESS_TOKEN_TTL_MIN=15                                   # ALL
JWT_REFRESH_TOKEN_TTL_DAYS=14                                 # ALL

# KEK (Key-Encryption-Key) for envelope encryption of broker credentials.
# 32 raw bytes, base64 encoded. dev.sh will generate one if PLACEHOLDER.
ENCRYPTION_KEK_BASE64=PLACEHOLDER_ENCRYPTION_KEK_REPLACE_ME   # RAILWAY — openssl rand -base64 32
ENCRYPTION_KEY_VERSION=1                                      # RAILWAY

# CORS
CORS_ORIGINS=http://localhost:3000                            # RAILWAY = https://your-app.vercel.app

# URLs used in email templates + Stripe redirects (Phase 2)
FRONTEND_URL=http://localhost:3000                            # RAILWAY = https://your-app.vercel.app
BACKEND_PUBLIC_URL=http://localhost:8000                      # RAILWAY = https://${{RAILWAY_PUBLIC_DOMAIN}}

# ---------------------------------------------------------------------------
# Frontend (Next.js 15)
# ---------------------------------------------------------------------------
# IMPORTANT: include /api/v1 — backend mounts routers under this prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1              # VERCEL = https://<railway-backend>/api/v1
NEXTAUTH_URL=http://localhost:3000                            # VERCEL = https://your-app.vercel.app
NEXTAUTH_SECRET=PLACEHOLDER_NEXTAUTH_SECRET_REPLACE_ME        # VERCEL — openssl rand -base64 32

# ---------------------------------------------------------------------------
# Trading Engine
# ---------------------------------------------------------------------------
ENGINE_MODE=paper                    # RAILWAY (engine) — paper until gate passes, then live
MT5_BRIDGE_URL=http://mt5-bridge-stub:8500  # RAILWAY (engine) = Cloudflare Tunnel or Tailscale URL
BACKTEST_DATA_DIR=/app/data          # ALL
DEFAULT_RISK_PCT=1.0                 # RAILWAY (engine)
DEFAULT_RR=1.5                       # RAILWAY (engine)

# ---------------------------------------------------------------------------
# MT5 Bridge — stub vs real
# ---------------------------------------------------------------------------
# In dev: mt5-bridge-stub returns canned responses on port 8500.
# In prod: point to Windows VPS over WireGuard / Tailscale / Cloudflare Tunnel.
#   e.g. http://100.64.0.5:8500   (Tailscale)
#        https://bridge.example.com (Cloudflare Tunnel)
MT5_BRIDGE_MODE=stub                 # DEV=stub | RAILWAY=proxy
MT5_BRIDGE_MTLS_CERT=                # RAILWAY (engine) — optional mTLS
MT5_BRIDGE_MTLS_KEY=                 # RAILWAY (engine) — optional mTLS

# Bearer token shared with the Windows-side mt5-bridge. install.ps1 generates
# one and prints it once — paste it here. ≥ 32 chars; rotate every 90 days.
MT5_BRIDGE_TOKEN=PLACEHOLDER_MT5_BRIDGE_TOKEN_REPLACE_ME       # RAILWAY (engine)

# Same value as BRIDGE_TOKEN on the Windows host. Some clients prefer this
# explicit alias for symmetry; the engine reads MT5_BRIDGE_TOKEN.
BRIDGE_TOKEN=PLACEHOLDER_MT5_BRIDGE_TOKEN_REPLACE_ME            # WINDOWS_VPS (mirror)

# ---------------------------------------------------------------------------
# Internal API HMAC — shared between trading-engine /live and backend /internal
# ---------------------------------------------------------------------------
# The trading-engine signs every POST to /internal/signals|trades|health with
# HMAC-SHA256 over (method, path, ts, nonce, body_sha256). Backend (Atlas) uses
# this same secret to verify. Rotate together; mismatched secrets = 401.
INTERNAL_API_SECRET=PLACEHOLDER_INTERNAL_API_SECRET_REPLACE_ME  # RAILWAY (backend + engine, SAME value)
BACKEND_INTERNAL_URL=http://backend:8000                        # RAILWAY (engine) = http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:8000

# ---------------------------------------------------------------------------
# Stripe billing (Phase 2)
# ---------------------------------------------------------------------------
# Use `sk_test_*` in dev, `sk_live_*` in prod. Empty or `fake_*` prefix → the
# BillingService runs in offline mode (no network); tests stay deterministic.
STRIPE_API_KEY=                      # RAILWAY (backend) — sk_live_* or sk_test_*
STRIPE_WEBHOOK_SECRET=               # RAILWAY (backend) — whsec_* from Stripe Dashboard → Webhooks
# Run `python -m scripts.stripe_setup` to provision Prices, paste IDs here:
STRIPE_PRICE_PRO_MONTHLY=            # RAILWAY (backend)
STRIPE_PRICE_PRO_YEARLY=             # RAILWAY (backend)
STRIPE_PRICE_LIFETIME=               # RAILWAY (backend)
STRIPE_TRIAL_DAYS=14                 # RAILWAY (backend)
# Legacy aliases (keep both populated for backward compat)
STRIPE_PRICE_ID_PRO_MONTHLY=         # RAILWAY (backend)
STRIPE_PRICE_ID_PRO_YEARLY=          # RAILWAY (backend)

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://prometheus:9090  # DEV — RAILWAY: external OTLP collector if any
OTEL_SERVICE_NAME=forex-bot          # RAILWAY: forex-bot-backend | forex-bot-engine
SENTRY_DSN=                          # RAILWAY (backend + engine)
GRAFANA_USER=admin                   # DEV only
GRAFANA_PASSWORD=admin-dev           # DEV only

# ---------------------------------------------------------------------------
# Email delivery (Phase 2)
# ---------------------------------------------------------------------------
# Provider: console (dev default) | smtp | resend
# Invalid config falls back to console with a warning — never blocks signup.
EMAIL_PROVIDER=console               # DEV=console | RAILWAY=resend|smtp
EMAIL_FROM=noreply@forex-bot.local   # RAILWAY = noreply@yourdomain.com

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=                           # RAILWAY (backend) if EMAIL_PROVIDER=smtp
SMTP_PORT=587                        # RAILWAY (backend) if EMAIL_PROVIDER=smtp
SMTP_USER=                           # RAILWAY (backend)
SMTP_PASSWORD=                       # RAILWAY (backend)
SMTP_STARTTLS=true                   # RAILWAY (backend)

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=                      # RAILWAY (backend)

DISCORD_WEBHOOK_URL=                 # RAILWAY (backend)

# ---------------------------------------------------------------------------
# Per-tier rate limits (requests per minute) — Phase 2
# ---------------------------------------------------------------------------
RATE_LIMIT_FREE_PER_MIN=30           # RAILWAY (backend)
RATE_LIMIT_PRO_PER_MIN=120           # RAILWAY (backend)
RATE_LIMIT_PRO_YEARLY_PER_MIN=240    # RAILWAY (backend)
RATE_LIMIT_LIFETIME_PER_MIN=240      # RAILWAY (backend)

# ---------------------------------------------------------------------------
# Dev-only seed account (created by scripts/seed.py)
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@local         # DEV only — RAILWAY: use real email, rotate after first login
SEED_ADMIN_PASSWORD=changeme123      # DEV only — RAILWAY: openssl rand -base64 18

# ============================================================================
# Phase 2 — Production deploy keys
# (leave blank for dev; required when running `make deploy-prod`)
# ============================================================================

# Public domains served by Caddy. ACME cert is issued by Let's Encrypt.
DOMAIN=forexbot.example.com
API_DOMAIN=api.forexbot.example.com
ACME_EMAIL=ops@forexbot.example.com

# Postgres + Redis passwords used in prod compose (do NOT reuse the dev
# defaults above — generate with `openssl rand -base64 32`).
REDIS_PASSWORD=

# Admin IP allowlist for grafana.${DOMAIN} (CIDR list, space separated).
ADMIN_IP_ALLOWLIST=127.0.0.1/8

# ---------------------------------------------------------------------------
# Cloudflare (DNS + Tunnel + R2 backups)
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=

# ---------------------------------------------------------------------------
# R2 / S3 object storage for nightly Postgres backups + export downloads
# ---------------------------------------------------------------------------
R2_ENDPOINT=
R2_BUCKET=forex-bot-backups
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Alerting fanout (Alertmanager → on-call)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
ALERT_EMAIL_TO=alerts@forexbot.example.com

# ---------------------------------------------------------------------------
# Risk disclaimer / consent version (frontend + backend reference the same
# constant so audit rows can be matched to displayed text). Update both the
# constant in `frontend/src/components/risk-disclaimer-modal.tsx` AND this
# value when the displayed text materially changes.
# ---------------------------------------------------------------------------
RISK_DISCLAIMER_VERSION=1.0.0
