# --- Local development defaults ---
# Copy to `.env.local` and tweak as needed. `pnpm dev` reads `.env.local`.

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# Optional — server-only override used by Server Components / route handlers.
# Useful when frontend + API live on a private network. Leave blank for MVP.
# API_URL_INTERNAL=http://api:8000/api/v1

# Auth (run `openssl rand -base64 32` to generate a strong secret)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Canonical base URL for Stripe success/cancel + OG images.
# In local dev leave blank — the app falls back to window.location.origin.
NEXT_PUBLIC_BASE_URL=

# DX — local development conveniences
# When true: prefills login form with admin@local / changeme123 and auto-signs-in after signup.
# IMPORTANT: must be `false` (or unset) in production.
NEXT_PUBLIC_DEV_MODE=true

# Telemetry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENV=development
NEXT_PUBLIC_POSTHOG_KEY=

# Feature flags
NEXT_PUBLIC_ENABLE_LIVE_TRADING=false
NEXT_PUBLIC_ENABLE_BINANCE=false

# Stripe — optional.
# We use Stripe-hosted Checkout (redirect), so the publishable key is NOT
# required client-side. Kept for a future Stripe Elements migration.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
