# ============================================================================
# Caddyfile — Forex Bot production reverse proxy
# ============================================================================
# Owner: Hestia Kaoru
# Last updated: 2026-06-15
#
# Caddy provides:
#   - Auto HTTPS via Let's Encrypt (HTTP-01 challenge by default)
#   - HTTP/2 + HTTP/3 (QUIC) automatic
#   - Real-IP from Cloudflare (cf-connecting-ip)
#   - HSTS, CSP, security headers
#   - Edge rate limiting (caddy-ratelimit module)
#   - Access logging in JSON → /var/log/caddy/access.log (collected by Promtail)
#
# Domains (override via .env.prod):
#   DOMAIN          = forexbot.example.com         → frontend
#   API_DOMAIN      = api.forexbot.example.com     → backend
#   GRAFANA_DOMAIN  = grafana.forexbot.example.com → grafana (admin only)
#
# Cloudflare in front of Caddy (Full Strict mode) → Caddy obtains its own
# Let's Encrypt cert; CF re-encrypts. SSL/TLS termination happens here.
# ============================================================================

{
	# Global options
	email {$ACME_EMAIL:ops@forexbot.example.com}
	admin 0.0.0.0:2019
	servers {
		trusted_proxies static \
