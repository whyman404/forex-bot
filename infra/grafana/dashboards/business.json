{
  "annotations": {"list": []},
  "description": "Forex Bot — Business KPIs (signups, MRR, churn, backtests). Owner: Hestia.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "expr": "increase(signups_total[1d])",
          "refId": "A"
        }
      ],
      "title": "Signups today",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area"},
      "targets": [
        {"expr": "active_subscriptions", "refId": "A"}
      ],
      "title": "Active subscriptions",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area"},
      "targets": [
        {"expr": "sum(monthly_recurring_revenue_usd)", "refId": "A"}
      ],
      "title": "MRR",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "100 * (increase(subscription_canceled_total[30d]) / clamp_min(active_subscriptions offset 30d, 1))",
          "refId": "A"
        }
      ],
      "title": "30d churn %",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 10,
      "targets": [
        {"expr": "increase(signups_total[1h])", "legendFormat": "signups/h", "refId": "A"},
        {"expr": "increase(subscription_created_total[1h])", "legendFormat": "new_subs/h", "refId": "B"},
        {"expr": "increase(subscription_canceled_total[1h])", "legendFormat": "cancels/h", "refId": "C"}
      ],
      "title": "Funnel rates (per hour)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "bars", "fillOpacity": 50}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 11,
      "targets": [
        {"expr": "sum by (strategy_code) (increase(backtests_completed_total[1d]))", "legendFormat": "{{strategy_code}}", "refId": "A"}
      ],
      "title": "Backtests completed today by strategy",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(backtest_duration_seconds_bucket[1h])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(backtest_duration_seconds_bucket[1h])))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "title": "Backtest duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line"}, "unit": "percent"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 13,
      "targets": [
        {"expr": "100 * (sum(rate(backtests_completed_total[1d])) / sum(rate(backtests_queued_total[1d])))", "legendFormat": "completion %", "refId": "A"}
      ],
      "title": "Backtest completion rate",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["forex-bot", "business"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "name": "DS_PROM",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "title": "Forex Bot — Business",
  "uid": "forex-bot-business",
  "version": 1
}
