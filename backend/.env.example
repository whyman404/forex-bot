# ===== App =====
APP_ENV=development
APP_NAME=forex-bot-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false

# ===== Server =====
# PORT is auto-injected by Railway / Render / Fly. Default 8000 for local.
HOST=0.0.0.0
PORT=8000
# CORS — primary origins. CSV or JSON list.
CORS_ORIGINS=["http://localhost:3000","https://app.forexbot.local"]
# Preview-deploy domains (CSV). E.g. Vercel preview branches.
FRONTEND_URLS_EXTRA=
# Regex pattern for preview hosts. Default matches *.vercel.app.
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*vercel\.app$

# ===== Database =====
# Railway provides DATABASE_URL as postgres://...  (no driver suffix).
# Neon provides postgresql://...?sslmode=require.
# We auto-normalize to postgresql+asyncpg://... and auto-detect SSL.
DATABASE_URL=postgresql+asyncpg://forex:forex@localhost:5432/forex_bot
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE_SECONDS=300

# ===== Redis =====
# redis://  for Railway/self-host, rediss://  for Upstash / managed TLS.
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT_DB=1
REDIS_SESSION_DB=2
REDIS_SOCKET_TIMEOUT_SECONDS=5

# ===== JWT (Argus owns rotation policy) =====
JWT_SECRET_KEY=change-me-in-production-32-bytes-min
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MIN=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=forex-bot
JWT_AUDIENCE=forex-bot-api

# ===== Envelope Encryption (per ADR-005) =====
# KEK comes from KMS/secret manager in prod. For local dev, base64-encoded 32 bytes.
ENCRYPTION_KEK_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ENCRYPTION_KEY_VERSION=1

# ===== Stripe =====
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ID_PRO_YEARLY=price_xxx

# ===== Observability =====
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=forex-bot-backend
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ===== Email (transactional) =====
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@forexbot.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@forexbot.local
RESEND_API_KEY=

# ===== Rate limit defaults =====
RATE_LIMIT_DEFAULT_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_BURST=20

# ===== TOTP =====
TOTP_ISSUER=ForexBot

# ===== Public URLs (used in email templates + Stripe redirects) =====
# In Railway, set FRONTEND_URL to your Vercel domain after first deploy.
# Until then, RAILWAY_PUBLIC_DOMAIN is used as fallback automatically.
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000

# ===== Internal service trust =====
INTERNAL_API_SECRET=
# CIDR allowlist for trading-engine → backend internal calls (HMAC stays primary).
# Optional defense-in-depth; leave blank to disable.
INTERNAL_TRUSTED_PROXY_CIDRS=

# ===== Lifecycle =====
# Opt-in: run alembic upgrade head at app boot, guarded by Postgres advisory
# lock. Recommended OFF — use the release/post-deploy script instead.
RUN_MIGRATIONS_ON_BOOT=false
SHUTDOWN_GRACE_SECONDS=10

# ===== Railway-injected (DO NOT SET BY HAND in prod) =====
# These appear automatically inside a Railway service container.
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_SERVICE_NAME=
# RAILWAY_ENVIRONMENT_NAME=
