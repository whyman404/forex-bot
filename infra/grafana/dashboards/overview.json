{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Forex Bot — Overview (RED + uptime). Owner: Hestia Kaoru.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.99},
              {"color": "green", "value": 0.999}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{job=\"backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"backend\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "Backend availability (5xx rate)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1.0}
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "Backend p95 latency",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"backend\"}[1m]))",
          "refId": "A"
        }
      ],
      "title": "Request rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "targets": [
        {"expr": "up{job=\"backend\"}",        "legendFormat": "backend",        "refId": "A"},
        {"expr": "up{job=\"frontend\"}",       "legendFormat": "frontend",       "refId": "B"},
        {"expr": "up{job=\"trading-engine\"}", "legendFormat": "trading-engine", "refId": "C"},
        {"expr": "up{job=\"mt5-bridge\"}",     "legendFormat": "mt5-bridge",     "refId": "D"},
        {"expr": "up{job=\"postgres\"}",       "legendFormat": "postgres",       "refId": "E"},
        {"expr": "up{job=\"redis\"}",          "legendFormat": "redis",          "refId": "F"}
      ],
      "title": "Service health",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 10,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Backend latency (RED — duration)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 11,
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{job=\"backend\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Backend requests by status (RED — rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {"unit": "short"}
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 12,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(10, sum by (route, status) (rate(http_requests_total{job=\"backend\",status=~\"5..\"}[15m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Top 10 routes returning 5xx (last 15m)",
      "type": "table"
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "id": 13,
      "options": {
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"backend\"} |~ \"ERROR|CRITICAL\" | json | line_format \"{{.level}} {{.event}} {{.error}}\"",
          "refId": "A"
        }
      ],
      "title": "Recent backend errors",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["forex-bot", "overview"],
